    { "path": "/va-masterclass", "prerender": true },
    { "path": "/thank-you", "prerender": true },
    { "path": "/referral-progress", "prerender": true },
    { "path": "/odosa-egharevba", "prerender": true },
    { "path": "/affiliate", "prerender": true },
    { "path": "/login", "prerender": false },
